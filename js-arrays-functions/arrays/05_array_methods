//Check for an item belongs to an Array (includes)
const num = [1, 2, 3];
console.log(num.includes(2)); // true
const pets = ['cat', 'dog', 'bat'];
console.log(pets.includes('cat')); // true
console.log(pets.includes('at')); // false

//Check every items pass a criteria (every)
const arr = [1, 30, 39, 29, 10, 13];
console.log(arr.every(x => x < 40)); // true
console.log(arr.every(x => x < 30)); // false



//Can we process arrays without loops?
//map filter reduce

let marks=[10,20,30];

let bonus=marks.map(x=>x+5);

console.log(marks);

console.log(bonus);

//Create new array which pass a criteria (filter)
const arr1 = [1, 30, 39, 29, 10, 13];
console.log(arr1.filter(x => x < 30)); // [1, 29, 10, 13]
console.log(arr1.filter(x => x < 20)); // [1, 10, 13]

